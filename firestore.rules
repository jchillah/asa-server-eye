rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function currentUserDoc() {
      return userDoc(request.auth.uid);
    }

    function currentUserExists() {
      return isSignedIn() && exists(currentUserDoc());
    }

    function accessLevel() {
      return currentUserExists()
        ? get(currentUserDoc()).data.sightingsAccessLevel
        : 'free';
    }

    function isAdmin() {
      return accessLevel() == 'admin';
    }

    function isPremiumOrAdmin() {
      return accessLevel() == 'premium' || isAdmin();
    }

    function isOwner(data) {
      return isSignedIn() && data.createdByUserId == request.auth.uid;
    }

    function validPlatform(p) {
      return p in ['steam', 'xbox', 'psn', 'unknown'];
    }

    function validCreatorLevel(c) {
      return c in ['free', 'premium', 'admin'];
    }

    function validSharingScope(s) {
      return s in ['ownerOnly', 'premiumShared', 'adminOnly'];
    }

    // -------- USERS --------
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'username',
          'usernameLower',
          'email',
          'photoUrl',
          'favoriteIds',
          'sightingsAccessLevel',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 20
        && request.resource.data.usernameLower is string
        && request.resource.data.usernameLower.size() >= 3
        && request.resource.data.usernameLower.size() <= 20
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && (
          request.resource.data.photoUrl == null
          || request.resource.data.photoUrl is string
        )
        && request.resource.data.favoriteIds is list
        && request.resource.data.favoriteIds.size() == 0
        && request.resource.data.sightingsAccessLevel == 'free'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'username',
          'usernameLower',
          'email',
          'photoUrl',
          'favoriteIds',
          'sightingsAccessLevel',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 20
        && request.resource.data.usernameLower is string
        && request.resource.data.usernameLower.size() >= 3
        && request.resource.data.usernameLower.size() <= 20
        && request.resource.data.email == resource.data.email
        && (
          request.resource.data.photoUrl == null
          || request.resource.data.photoUrl is string
        )
        && request.resource.data.favoriteIds is list
        && request.resource.data.sightingsAccessLevel == resource.data.sightingsAccessLevel
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;

      allow delete: if isSignedIn()
        && request.auth.uid == uid;
    }

    // -------- PLAYER SIGHTINGS --------
    match /player_sightings/{sightingId} {

      function canReadSighting(data) {
        return isAdmin()
          || isOwner(data)
          || (
            data.isVisible == true
            && data.sharingScope == 'premiumShared'
            && isPremiumOrAdmin()
          );
      }

      allow read: if isSignedIn() && canReadSighting(resource.data);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'serverId',
          'playerPlatformId',
          'inGameName',
          'tribeName',
          'platform',
          'createdAt',
          'createdByUserId',
          'createdByUsername',
          'creatorLevel',
          'sharingScope',
          'isVisible',
          'note',
          'updatedAt',
          'updatedByUserId',
          'deletedAt',
          'deletedByUserId',
          'deleteReason'
        ])
        && request.resource.data.serverId is string
        && request.resource.data.serverId.size() > 0
        && request.resource.data.playerPlatformId is string
        && request.resource.data.playerPlatformId.size() > 0
        && request.resource.data.inGameName is string
        && request.resource.data.inGameName.size() > 0
        && request.resource.data.tribeName is string
        && request.resource.data.tribeName.size() > 0
        && request.resource.data.createdByUserId == request.auth.uid
        && request.resource.data.createdByUsername is string
        && request.resource.data.createdByUsername.size() > 0
        && validPlatform(request.resource.data.platform)
        && validCreatorLevel(request.resource.data.creatorLevel)
        && validSharingScope(request.resource.data.sharingScope)
        && request.resource.data.isVisible == true
        && request.resource.data.updatedAt == null
        && request.resource.data.updatedByUserId == null
        && request.resource.data.deletedAt == null
        && request.resource.data.deletedByUserId == null
        && request.resource.data.deleteReason == null
        && (
          (accessLevel() == 'free'
            && request.resource.data.creatorLevel == 'free'
            && request.resource.data.sharingScope == 'ownerOnly')
          ||
          (accessLevel() == 'premium'
            && request.resource.data.creatorLevel == 'premium'
            && request.resource.data.sharingScope in ['ownerOnly', 'premiumShared'])
          ||
          (accessLevel() == 'admin'
            && request.resource.data.creatorLevel == 'admin')
        );

      allow update: if isSignedIn()
        && (
          (
            isOwner(resource.data)
            && resource.data.isVisible == true
            && request.resource.data.serverId == resource.data.serverId
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.createdByUserId == resource.data.createdByUserId
            && request.resource.data.creatorLevel == resource.data.creatorLevel
            && request.resource.data.isVisible == true
            && (
              resource.data.creatorLevel == 'free'
                ? request.resource.data.sharingScope == 'ownerOnly'
                : resource.data.creatorLevel == 'premium'
                  ? request.resource.data.sharingScope in ['ownerOnly', 'premiumShared']
                  : true
            )
          )
          ||
          (
            (isOwner(resource.data) || isAdmin())
            && request.resource.data.serverId == resource.data.serverId
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.createdByUserId == resource.data.createdByUserId
            && request.resource.data.isVisible == false
            && request.resource.data.deletedByUserId == request.auth.uid
            && request.resource.data.deleteReason is string
            && request.resource.data.deleteReason.size() > 0
          )
          ||
          (
            isAdmin()
            && request.resource.data.serverId == resource.data.serverId
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.createdByUserId == resource.data.createdByUserId
          )
        );

      allow delete: if false;
    }

    // -------- HISTORY --------
    match /player_sighting_history/{historyId} {
      function sightingDocPath(sightingId) {
        return /databases/$(database)/documents/player_sightings/$(sightingId);
      }

      function referencedSightingExists() {
        return request.resource.data.sightingId is string
          && request.resource.data.sightingId.size() > 0
          && exists(sightingDocPath(request.resource.data.sightingId));
      }

      function canWriteHistory() {
        return referencedSightingExists()
          && (
            isAdmin()
            || get(sightingDocPath(request.resource.data.sightingId)).data.createdByUserId == request.auth.uid
          );
      }

      allow read: if isSignedIn()
        && (
          isAdmin()
          || (resource.data.sightingId is string
              && exists(sightingDocPath(resource.data.sightingId))
              && get(sightingDocPath(resource.data.sightingId)).data.createdByUserId == request.auth.uid)
        );

      allow create: if isSignedIn()
        && canWriteHistory()
        && request.resource.data.keys().hasOnly([
          'sightingId','action','changedAt','changedByUserId','summary','beforeData','afterData'
        ])
        && request.resource.data.changedByUserId == request.auth.uid
        && request.resource.data.action in ['created','updated','softDeleted']
        && request.resource.data.summary is string
        && request.resource.data.summary.size() > 0;

      allow update, delete: if false;
    }

    // -------- ADMIN META --------
    match /player_sighting_admin_meta/{sightingId} {
      allow read, write: if isSignedIn() && isAdmin();
    }
  }
}